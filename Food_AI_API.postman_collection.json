		{
			"name": "3. Predict - Valid Image (Success Case)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response has menu_name', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('menu_name');",
							"    pm.expect(json).to.have.property('confidence');",
							"    pm.expect(json).to.have.property('nutrition');",
							"});",
							"",
							"pm.test('Confidence is between 0 and 1', function () {",
							"    var json = pm.response.json();",
							"    pm.expect(json.confidence).to.be.within(0, 1);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": "/path/to/your/food_image.jpg",
							"description": "อัปโหลดไฟล์รูปภาพอาหาร (JPEG/PNG/WEBP, ≤ 5MB)"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/predict",
					"host": ["{{base_url}}"],
					"path": ["predict"]
				},
				"description": "ส่งรูปภาพให้ AI ทำนายเมนูอาหาร + ข้อมูลโภชนาการ"
			},
			"response": [
				{
					"name": "Success Example",
					"originalRequest": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "file", "type": "file", "src": "" }
							]
						},
						"url": {
							"raw": "{{base_url}}/predict",
							"host": ["{{base_url}}"],
							"path": ["predict"]
						}
					},
					"status": "OK",
					"code": 200,
					"_postman_previewlanguage": "json",
					"header": [
						{ "key": "content-type", "value": "application/json" }
					],
					"body": "{\n  \"status\": \"success\",\n  \"menu_name\": \"hamburger\",\n  \"name_th\": \"hamburger\",\n  \"confidence\": 0.9854,\n  \"inference_time_ms\": 65.2,\n  \"nutrition\": {\n    \"calories\": 450,\n    \"protein\": 20.0,\n    \"carbs\": 40.0,\n    \"fat\": 25.0\n  }\n}"
				}
			]
		},
